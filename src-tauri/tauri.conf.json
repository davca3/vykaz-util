{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vykaz",
  "version": "0.7.0",
  "identifier": "com.vykaz.util",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3007",
    "beforeDevCommand": "npm run dev -- --port 3007",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["vykaz"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyMjA2Njk5ODAzQzJDQzEKUldUQkxEeUFtV1lnNGhiWGdtemo4MWR0ZnJUbThQUkg0TFlyMWdEa2ZVaXI5bjFvVHc2VDlGdmQK",
      "endpoints": [
        "https://github.com/davca3/vykaz-util/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "Výkaz práce",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist"
    }
  }
}
