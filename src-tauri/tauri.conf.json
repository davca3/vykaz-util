{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Výkaz práce",
  "version": "0.1.0",
  "identifier": "com.vykaz.util",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3007",
    "beforeDevCommand": "npm run dev -- --port 3007",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Výkaz práce",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist"
    }
  }
}
